# ---- Google Calendar API ----
# Google Cloud Console で OAuth 2.0 クライアントを作成して取得
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# シフトを書き込むカレンダーのID（"primary" = 各ユーザーのメインカレンダー）
GOOGLE_CALENDAR_ID=primary

# ---- Slack App ----
# Slack App の設定画面から取得
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...

# シフト報告を監視するチャンネルのID（空欄 = 全チャンネル監視）
SLACK_WATCH_CHANNEL_ID=

# アプリの公開URL（Slack返信の登録リンクに使用）
APP_URL=http://localhost:3000

# トークン保存先（省略時: ./data/tokens.json）
# TOKEN_STORE_PATH=
